# career-ops — Environment Variables
# Copy this file to .env and fill in your values.
#
#   cp .env.example .env

# ── Gemini Integration (Issue #344) ─────────────────────────────────────────
# Required for: node gemini-eval.mjs "JD text here"
# Free API key: https://aistudio.google.com/apikey
# Free tier: 15 RPM / 1M tokens/day with gemini-2.5-flash (no billing needed)
GEMINI_API_KEY=your_gemini_api_key_here

# ── Optional: Override default Gemini model ───────────────────────────────────
# Default: gemini-2.5-flash (free-tier, fast)
# Alternatives: gemini-1.5-flash, gemini-1.5-pro, gemini-2.5-flash-thinking-exp
# GEMINI_MODEL=gemini-2.5-flash

# ── Other integrations (add your own below) ──────────────────────────────────
# ANTHROPIC_API_KEY=your_anthropic_key_here   # For Claude-based workflows
# OPENAI_API_KEY=your_openai_key_here          # Future OpenAI integration

# ── Ollama Integration (local, zero-cost) ────────────────────────────────────
# Required for: node ollama-eval.mjs --file ./jds/job.txt
# Install Ollama: https://ollama.ai
# Recommended: qwen2.5:14b (faster, 100% GPU on 16 GB VRAM, no thinking overhead)
# Alternative: qwen3:14b (thinking mode — disable with think:false, may CPU-offload at 16k ctx)
OLLAMA_HOST=http://localhost:11434
OLLAMA_MODEL=qwen2.5:14b
OLLAMA_TIMEOUT_MS=120000

# ── Russian Market Settings ───────────────────────────────────────────────────
# RU_MARKET=true enables Russian-market-specific logic in future scanners
RU_MARKET=true
# Comma-separated hh.ru area IDs: 1=Москва, 2=Санкт-Петербург
HH_AREA=1,2
# Required by hh.ru API to avoid rate limiting. Use real email.
HH_USER_AGENT=career-ops-local/1.0 (your-email@example.com)
# Default language for ollama-eval (ru|en)
DEFAULT_LANG=ru
# Telegram RSS proxy for channel scanning (third-party, may be unstable)
TG_RSS_PROXY=https://tg.i-c-a.su/rss
